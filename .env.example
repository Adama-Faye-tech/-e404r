# E404R — Engine 404 Router
# Environment Configuration
# "One Gateway. Infinite Intelligence."
#
# Copy this file to .env and fill in your values before starting E404R.

# ─────────────────────────────────────────────
# REQUIRED — Security (must change before deploy)
# ─────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars
INITIAL_PASSWORD=change-me

# Data storage directory (default: ~/.e404r/ on Linux/Mac, AppData\e404r on Windows)
DATA_DIR=/var/lib/e404r

# ─────────────────────────────────────────────
# RUNTIME
# ─────────────────────────────────────────────
PORT=20128
NODE_ENV=production

# E404R instance name (displayed in dashboard header)
INSTANCE_NAME=E404R

# ─────────────────────────────────────────────
# SECURITY & API
# ─────────────────────────────────────────────
# Secret for signing proxy API keys (share with clients connecting to /v1/*)
API_KEY_SECRET=change-me-api-key-secret

# Machine identity salt (used for hardware-bound tokens)
MACHINE_ID_SALT=change-me-machine-salt

# Enable request logging to disk (~/.e404r/log.txt)
ENABLE_REQUEST_LOGS=false

# Enable Prometheus-compatible observability metrics at /api/metrics
OBSERVABILITY_ENABLED=true

# Require secure cookies (set true behind HTTPS reverse proxy)
AUTH_COOKIE_SECURE=false

# Require API key for all /v1/* requests
REQUIRE_API_KEY=false

# ─────────────────────────────────────────────
# BASE URLs (for cloud sync & internal callbacks)
# ─────────────────────────────────────────────
BASE_URL=http://localhost:20128
NEXT_PUBLIC_BASE_URL=http://localhost:20128

# E404R Cloud URL (if using cloud sync features)
# CLOUD_URL=https://your-e404r-instance.com
# NEXT_PUBLIC_CLOUD_URL=https://your-e404r-instance.com

# ─────────────────────────────────────────────
# OUTBOUND PROXY (for upstream provider calls)
# ─────────────────────────────────────────────
# Lowercase variants also supported: http_proxy, https_proxy, all_proxy, no_proxy
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# ALL_PROXY=socks5://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1

# ─────────────────────────────────────────────
# SMART ROUTER (E404R Intelligence Layer)
# ─────────────────────────────────────────────
# Enable the Smart AI Router engine
E404R_SMART_ROUTER=true

# Smart router strategy: cost | quality | speed | balanced
E404R_ROUTING_STRATEGY=balanced

# Max response time before failover (ms)
E404R_FAILOVER_TIMEOUT_MS=30000

# ─────────────────────────────────────────────
# LOCAL AI (Ollama, llama.cpp)
# ─────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434

# ─────────────────────────────────────────────
# SEARCH PROVIDERS
# ─────────────────────────────────────────────
# Optional SearXNG endpoint for built-in web search
# SEARXNG_URL=http://searxng:8080/search

# ─────────────────────────────────────────────
# ADVANCED (rarely needed)
# ─────────────────────────────────────────────
# Max request body size for /v1/* routes (default: 128mb)
# E404R_PROXY_CLIENT_MAX_BODY_SIZE=128mb

# Build output directory override
# NEXT_DIST_DIR=.next
